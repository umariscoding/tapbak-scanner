{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "API_BASE_URL": "https://api.tapbak.co" }
    },
    "preview": {
      "distribution": "internal",
      "env": { "API_BASE_URL": "https://api.tapbak.co" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "API_BASE_URL": "https://api.tapbak.co" }
    }
  },
  "submit": {
    "production": {}
  }
}
